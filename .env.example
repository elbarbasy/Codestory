# Environment variables example for CodeStory (Next.js + Supabase)

# Supabase public values (client-side)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Owner admin email (used to restrict dashboard access)
NEXT_PUBLIC_OWNER_EMAIL=codestory26@gmail.com

# Optional if you add email notifications later
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# NextAuth secret if used
# NEXTAUTH_SECRET=
